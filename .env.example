# ============================================================
# Lacuna Falsification — Environment Template
# ============================================================
# Copy to `.env` (gitignored) and fill in real values locally.
# NEVER commit `.env` to the repo.
# ============================================================

# ---- Anthropic API ----
ANTHROPIC_API_KEY=sk-ant-...
# Optional: organization id (multi-org users only)
ANTHROPIC_ORG_ID=

# ---- Model selection ----
OPUS_MODEL=claude-opus-4-7
SONNET_MODEL=claude-sonnet-4-6
MANAGED_AGENTS_BETA=managed-agents-2026-04-01

# ---- HPC access (values local-only, never committed) ----
# SSH alias from ~/.ssh/config (pre-configured on contributor machine)
HPC_SSH_ALIAS=
# Remote scratch path (contributor-specific)
HPC_SCRATCH=
# Slurm sbatch binary (version-specific; default HPC path may not work over SSH)
HPC_SBATCH=

# ---- Local paths ----
LOCAL_DATA_DIR=./data
LOCAL_ARTIFACTS_DIR=./artifacts

# ---- Cost ledger ----
COST_LEDGER_PATH=./artifacts/cost_ledger.jsonl
COST_KILL_SWITCH_USD=350

# ---- Optional: CI/deployment tokens ----
GITHUB_TOKEN=
